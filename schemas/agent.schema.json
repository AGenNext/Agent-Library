{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgenNext Agent Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "domain",
    "summary",
    "status",
    "capabilities"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["experimental", "beta", "stable", "deprecated"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interfaces": {
      "type": "object"
    },
    "runtime": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
